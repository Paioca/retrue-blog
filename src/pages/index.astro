<!-- ═══════════════════ JAVASCRIPT ═══════════════════ -->
<script is:inline>
/* --- Scroll Reveal --- */
var ro = new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('vis');ro.unobserve(e.target)}})}, {threshold:.1});
document.querySelectorAll('.rv').forEach(function(el){ro.observe(el)});

/* --- Sticky Mobile CTA --- */
new IntersectionObserver(function(es){document.getElementById('sm').classList.toggle('show',!es[0].isIntersecting)},{threshold:0}).observe(document.querySelector('section'));

/* --- FAQ --- */
function togFaq(btn){var i=btn.closest('.faq-item'),o=i.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(function(x){x.classList.remove('open')});if(!o)i.classList.add('open')}

/* --- Email Capture -> Redirect to App Login --- */
var APP_LOGIN=window.location.hostname==='localhost'?'http://localhost:3000/login':'https://app.revtrue.tech/login';
function handleSubmit(e,id){
  e.preventDefault();
  var inp=document.getElementById(id+'-email'), msg=document.getElementById(id+'-msg');
  var v=inp.value.trim();
  msg.textContent=''; msg.className='text-xs mt-2 min-h-[18px]';
  // format check
  if(!v||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)){
    msg.textContent='Please enter a valid email address.';
    msg.classList.add('text-rd','font-medium');
    inp.style.borderColor='#D94F3D';
    setTimeout(function(){inp.style.borderColor='';},2000);
    return false;
  }
  // Redirect to app with email prefilled
  window.location.href=APP_LOGIN+'?email='+encodeURIComponent(v);
  return false;
}

/* --- Demo Engine --- */
var STP=[
  {n:'Upload',d:2800,tab:null},
  {n:'Processing',d:2400,tab:null},
  {n:'Dashboard',d:3200,tab:'summary'},
  {n:'Stage Journey',d:3600,tab:'stagejourney'},
  {n:'Cohort Comparison',d:3000,tab:'cohort'},
  {n:'Time Series',d:3000,tab:'timeseries'}
];
var cs=0,dt=null,ds=false;
var dl=document.getElementById('dl'),dd=document.getElementById('dd'),dtabs=document.getElementById('dtabs');

STP.forEach(function(_,i){var d=document.createElement('div');d.className='h-2 rounded-full cursor-pointer transition-all duration-200 '+(i===0?'w-6 bg-ac':'w-2 bg-bdr');d.onclick=function(){go(i)};dd.appendChild(d)});

function showTabs(tabKey){
  if(!tabKey){dtabs.style.display='none';dtabs.style.opacity='0';return;}
  dtabs.style.display='flex';
  requestAnimationFrame(function(){dtabs.style.opacity='1'});
  document.querySelectorAll('.dtab').forEach(function(t){
    t.classList.toggle('dtab-on',t.dataset.t===tabKey);
  });
}

function go(i){
  clearTimeout(dt); cs=i;
  document.querySelectorAll('.demo-step').forEach(function(s){s.classList.remove('active')});
  var dots=dd.children;
  for(var x=0;x<dots.length;x++){dots[x].className='h-2 rounded-full cursor-pointer transition-all duration-200 '+(x===i?'w-6 bg-ac':'w-2 bg-bdr')}
  document.querySelector('.demo-step[data-step="'+i+'"]').classList.add('active');
  dl.textContent=STP[i].n;
  showTabs(STP[i].tab);
  anim(i);
  if(i<STP.length-1) dt=setTimeout(function(){go(i+1)},STP[i].d);
}

function anim(i){
  /* Step 0: Upload */
  if(i===0){
    var z=document.getElementById('uz'),f=document.getElementById('uf'),a=document.getElementById('t1'),b=document.getElementById('t2');
    z.style.borderColor='';z.style.background='';f.style.opacity='0';f.style.transform='translateY(8px)';a.style.opacity='0';b.style.opacity='0';
    setTimeout(function(){z.style.borderColor='#E86C3A';z.style.background='rgba(232,108,58,.03)'},300);
    setTimeout(function(){f.style.opacity='1';f.style.transform='translateY(0)'},800);
    setTimeout(function(){a.style.opacity='1'},1400);
    setTimeout(function(){b.style.opacity='1'},1800);
  }
  /* Step 1: Processing */
  if(i===1){
    var ps=document.querySelectorAll('#pl .pi');
    ps.forEach(function(p){p.style.opacity='0';p.style.transform='translateX(-8px)';p.style.color=''});
    ps.forEach(function(p,x){setTimeout(function(){p.style.opacity='1';p.style.transform='translateX(0)';p.style.color='#1A1A1A'},400+x*450)});
  }
  /* Step 2: Dashboard */
  if(i===2){
    var ks=document.querySelectorAll('#kg .kp-anim');
    ks.forEach(function(k){k.classList.remove('vis2');var kv=k.querySelector('.kv');if(kv)kv.textContent='0'});
    document.getElementById('wr-g').style.width='0';
    document.getElementById('wr-r').style.width='0';
    // Reset sparkline
    var sp=document.querySelector('#sparkline .chart-line');
    if(sp){sp.classList.remove('draw');sp.style.strokeDashoffset='1000';}

    ks.forEach(function(k,x){
      var delay=parseInt(k.dataset.delay||0)*120;
      setTimeout(function(){
        k.classList.add('vis2');
        var kv=k.querySelector('.kv');
        if(kv && k.dataset.v){
          var v=+k.dataset.v, s=k.dataset.s||'', p=k.dataset.p||'';
          cntUp(kv,v,p,s,900);
        }
      },200+delay);
    });
    setTimeout(function(){
      document.getElementById('wr-g').style.width='14.2%';
      document.getElementById('wr-r').style.width='85.8%';
    },600);
    // Sparkline draw
    setTimeout(function(){
      if(sp){sp.style.removeProperty('stroke-dashoffset');sp.classList.add('draw');}
    },1200);
  }
  /* Step 3: Stage Journey */
  if(i===3){
    var alert=document.getElementById('fn-alert');
    var head=document.getElementById('fn-head');
    var legend=document.getElementById('fn-legend');
    var rows=document.querySelectorAll('#fn .fn-row');
    alert.style.opacity='0'; head.style.opacity='0'; legend.style.opacity='0';
    rows.forEach(function(r){r.classList.remove('vis2');r.querySelectorAll('.funnel-seg').forEach(function(s){s.style.width='0'})});

    setTimeout(function(){alert.style.opacity='1'},200);
    setTimeout(function(){head.style.opacity='1'},500);

    rows.forEach(function(r,x){
      setTimeout(function(){
        r.classList.add('vis2');
        var segs=r.querySelectorAll('.funnel-seg');
        if(r.dataset.adv!==undefined){
          var a=parseFloat(r.dataset.adv),l=parseFloat(r.dataset.lost),o=parseFloat(r.dataset.open);
          if(segs[0])segs[0].style.width=a+'%';
          if(segs[1])segs[1].style.width=l+'%';
          if(segs[2])segs[2].style.width=o+'%';
        }
      },700+x*400);
    });
    setTimeout(function(){legend.style.opacity='1'},700+rows.length*400+200);
  }
  /* Step 4: Cohort */
  if(i===4){
    var rows=document.querySelectorAll('#ct .co-row');
    rows.forEach(function(r){r.classList.remove('vis2');r.querySelectorAll('.co-bar').forEach(function(b){b.style.width='0'})});
    rows.forEach(function(r,x){
      setTimeout(function(){
        r.classList.add('vis2');
        r.querySelectorAll('.co-bar').forEach(function(b){b.style.width=b.dataset.w});
      },200+x*180);
    });
  }
  /* Step 5: Time Series */
  if(i===5){
    var ls=document.querySelectorAll('.demo-step[data-step="5"] .chart-line');
    ls.forEach(function(l){l.classList.remove('draw');l.style.strokeDashoffset='1000'});
    setTimeout(function(){ls.forEach(function(l,x){setTimeout(function(){l.style.removeProperty('stroke-dashoffset');l.classList.add('draw')},x*250)})},300);
  }
}

function cntUp(el,t,p,s,dur){
  var st=performance.now();
  (function tick(now){
    var pr=Math.min((now-st)/dur,1);
    var ease=1-Math.pow(1-pr,3);
    el.textContent=p+Math.round(t*ease).toLocaleString()+s;
    if(pr<1)requestAnimationFrame(tick);
  })(st);
}

/* Auto-start */
var db=document.getElementById('demo-browser');
new IntersectionObserver(function(es){if(es[0].isIntersecting&&!ds){ds=true;setTimeout(function(){go(0)},300)}},{threshold:.25}).observe(db);
document.getElementById('dr').onclick=function(){ds=true;go(0)};
</script>
</body>
</html>
